# ─────────────────────────────────────────────────────────────────────────────
# PROJECT SPECIFIC
# ─────────────────────────────────────────────────────────────────────────────

# CSV files (scraped data - TOO LARGE for GitHub)
*.csv

# Pickle files (models)
*.pkl
*.pickle

# Data directory
data/

# Plots are ALLOWED on GitHub (small PNG files)
# Uncomment line below if you want to ignore plots:
# eda/plots/*.png

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON (GitHub auto-generated template)
# ─────────────────────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
